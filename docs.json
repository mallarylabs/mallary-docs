          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/upload",
              "api-reference/endpoint/create",
              "api-reference/endpoint/get",
              "api-reference/endpoint/posts",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/analytics",
              "api-reference/endpoint/platforms",
              "api-reference/endpoint/disconnect",
              "api-reference/endpoint/webhooks-list",
              "api-reference/endpoint/webhooks-create",
              "api-reference/endpoint/webhooks-delete"
