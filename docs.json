  },
  "logo": {
    "light": "/logo/mallary-light-v2.png",
    "dark": "/logo/mallary-dark-v2.png"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Welcome",
        "groups": [
