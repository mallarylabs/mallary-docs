{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Mallary.ai API, MCP, CLI Developer Docs",
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Mallary.ai API, MCP, CLI Developer Docs"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "colors": {
    "primary": "#fe9a00",
    "light": "#fe9a00",
    "dark": "#e17100"
